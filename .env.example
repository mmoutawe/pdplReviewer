# ─── Frontend (Vite) — exposed to browser ────────────────────────────────────
# Copy to .env.local and fill in values from:
#   Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Edge Function secrets ────────────────────────────────────────────────────
# Set via: supabase secrets set KEY=value --project-ref <ref>
# Or in Supabase Dashboard → Edge Functions → Secrets
#
# Required by: ai-stream, process-attachment
# ANTHROPIC_API_KEY=sk-ant-...
#
# Required by: email-notify (leave unset to skip email sending)
# RESEND_API_KEY=re_...
# EMAIL_FROM=PDPL Reviewer <noreply@yourcompany.com>
# APP_URL=https://pdpl.yourcompany.com
#
# Required by: email-notify webhook auth (generate with: openssl rand -hex 32)
# WEBHOOK_SECRET=your-random-secret-here

# ─── Local development only ───────────────────────────────────────────────────
# These are automatically set by `supabase start` for local dev.
# Never set SUPABASE_SERVICE_ROLE_KEY in browser-accessible environments.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
