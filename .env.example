# ─── Microsoft Dataverse ─────────────────────────────────────────────────────
# Your Dataverse / Power Platform environment URL (no trailing slash)
VITE_DATAVERSE_URL=https://yourorg.crm.dynamics.com

# Publisher prefix used when creating tables in your Dataverse solution (default: pdplr_)
# Must end with an underscore. Change only if you used a different publisher prefix.
VITE_DV_TABLE_PREFIX=pdplr_

# ─── Microsoft Entra ID (MSAL) ───────────────────────────────────────────────
# Azure App Registration → Overview
VITE_MSAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Your tenant ID (or "common" for multi-tenant)
VITE_MSAL_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Power Automate HTTP-triggered flows ─────────────────────────────────────
# AI streaming flow (replaces Supabase ai-stream Edge Function)
# Flow input: { feature, message, ticketId?, policyId?, context? }
# Flow output: Server-Sent Events stream with { token } / { done: true } payloads
VITE_PA_AI_STREAM_URL=https://prod-xx.westeurope.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke

# External link flows — three separate flows, each with its own trigger URL
# Flow: Generate External Link  (requires Bearer auth)
VITE_PA_EL_GENERATE_URL=https://prod-xx.westeurope.logic.azure.com/workflows/aaa/triggers/manual/paths/invoke
# Flow: Redeem External Link  (no auth — called by unauthenticated recipients)
VITE_PA_EL_REDEEM_URL=https://prod-xx.westeurope.logic.azure.com/workflows/bbb/triggers/manual/paths/invoke
# Flow: Submit External Decision  (no auth — called by unauthenticated recipients)
VITE_PA_EL_DECIDE_URL=https://prod-xx.westeurope.logic.azure.com/workflows/ccc/triggers/manual/paths/invoke

# Create-external-account flow (replaces create-external-account Edge Function)
# Flow input: { email, fullName, label, expiresAt }
# Flow output: { tempPassword, portalUrl }
VITE_PA_CREATE_ACCOUNT_URL=https://prod-xx.westeurope.logic.azure.com/workflows/zzz/triggers/manual/paths/invoke

# ─── Azure OpenAI (unchanged) ────────────────────────────────────────────────
# Required by: AI checklist, reviewer assessment, pre-submission assessment, request builder
VITE_AZURE_OPENAI_KEY=your-azure-openai-key
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
VITE_AZURE_OPENAI_DEPLOYMENT=gpt-5.1-chat
