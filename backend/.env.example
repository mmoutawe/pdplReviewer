# ─── PostgreSQL ───────────────────────────────────────────────────────────────
PGHOST=db
PGPORT=5432
PGDATABASE=pdplreviewer
PGUSER=pdpl
PGPASSWORD=change-me-in-production

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ─── AI — choose one provider ─────────────────────────────────────────────────

# Option A: Standard OpenAI
OPENAI_API_KEY=sk-...
OPENAI_DEPLOYMENT=gpt-4o

# Option B: Azure OpenAI (set AZURE_OPENAI_ENDPOINT to activate Azure path)
# AZURE_OPENAI_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ─── Seed admin account (used by: npm run seed) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@pdplreviewer.local
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_NAME=System Administrator
